---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
---

<html lang="es" class="font-outfit">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>DosD Solutions</title>
	</head>
	<body class="m-0 bg-slate-50 text-slate-800">
		<Navbar active="start" />
		
		<!-- Sección Hero -->
		<header class="relative w-full h-[700px] flex justify-center bg-gray-900 rounded-b-[3rem] overflow-hidden">
			<div class="absolute inset-0 bg-cover bg-[center_70%] bg-[url('/Santiago.jpg')] opacity-50"></div>
			<div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/50 to-transparent"></div>

			<!-- Contenedor del Texto -->
			<div class="relative z-10 w-full max-w-6xl px-10 pt-56">
				<h1 class="text-white text-6xl md:text-7xl font-bold leading-tight tracking-tight">
					Para buenas ventas, <br /> buenas herramientas!
					<span class="text-cyan-400 font-normal ml-2">&#123; &#125;</span>
				</h1>
				<p class="text-white text-2xl mt-6 font-light opacity-90">
					Soluciones personalizadas a tus necesidades
				</p>
			</div>
		</header>

		<!-- Contenido Principal -->
		<main class="relative z-20 w-full max-w-6xl mx-auto -mt-16 px-6 pb-24">
			
			<!-- Contenedor Blanco Central -->
			<div class="w-full bg-slate-50 md:bg-white md:rounded-t-[2.5rem] pt-12 md:shadow-sm flex flex-col">
				
				<!-- ==================== SECCIÓN: QUIENES SOMOS ==================== -->
				<div class="flex justify-center w-full">
					<h2 class="text-cyan-400 text-5xl font-bold tracking-tight">
						¿Quienes somos?
					</h2>
				</div>

				<div class="w-full max-w-5xl mx-auto mt-16 grid grid-cols-1 md:grid-cols-2 gap-16 px-8 mb-32">
					<!-- Columna Izquierda: Texto -->
					<div class="relative flex flex-col justify-center">
						<p class="text-slate-700 text-[1.05rem] leading-loose font-medium mb-6">
							<span class="text-6xl font-bold text-cyan-400 float-left mr-2 mt-2 leading-[0.7]">E</span>
							n DosD Solutions somos un equipo de desarrolladores especializados en la creación de software a medida. Nos enfocamos en construir herramientas tecnológicas que resuelven problemas reales de negocio.
						</p>
						<p class="text-slate-700 text-[1.05rem] leading-loose font-medium z-10">
							Desde plataformas sistemas de mensajería automatizadas a aplicaciones web de gestión, diseñamos arquitecturas robustas y escalables. Nuestro objetivo es entregar sistemas de alto rendimiento que optimicen los procesos operativos de nuestros clientes, permitiéndoles enfocarse en hacer crecer sus ventas.
						</p>

						<!-- Decoración inferior izquierda -->
						<div class="absolute -bottom-16 -left-16 -z-10 w-40 h-40">
							<svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="transform -rotate-12">
								<pattern id="gridPattern1" width="20" height="20" patternUnits="userSpaceOnUse">
									<path d="M 20 0 L 0 0 0 20" fill="none" stroke="#94a3b8" stroke-width="1" stroke-dasharray="2 2"/>
								</pattern>
								<rect width="200" height="200" fill="url(#gridPattern1)" />
								<circle cx="90" cy="80" r="35" fill="#0ea5e9" />
								<circle cx="120" cy="130" r="35" fill="#22d3ee" class="mix-blend-multiply" />
							</svg>
						</div>
					</div>

					<!-- Columna Derecha: Collage de Imágenes -->
					<div class="relative grid grid-cols-2 gap-4 items-center">
						<!-- Decoración superior -->
						<div class="absolute -top-10 left-12 w-10 h-10">
							<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="transform rotate-45">
								<path d="M 0 20 A 20 20 0 0 0 20 40 L 20 20 Z" fill="#0ea5e9" />
								<path d="M 20 0 A 20 20 0 0 0 40 20 L 20 20 Z" fill="#22d3ee" />
							</svg>
						</div>
						<!-- Imagen Izquierda -->
						<div class="col-span-1 bg-transparent">
							<img 
								src="/public/nosotros.jpg" 
								alt="Nosotros" 
								class="w-full object-cover rounded-2xl shadow-sm aspect-[4/5] object-[center_15%]"
								/>
						</div>
						<div class="col-span-1 flex flex-col gap-4">
							<img src="/imagen-postits.jpg" alt="Planificación" class="w-full object-cover rounded-2xl shadow-sm aspect-[4/3] bg-slate-200" />
							<img src="/imagen-escribiendo.jpg" alt="Escribiendo en computadora" class="w-full object-cover rounded-2xl shadow-sm aspect-[4/3] bg-slate-200" />
						</div>
					</div>
				</div>

				<!-- ==================== SECCIÓN: CONTACTO ==================== -->
				<div class="w-full max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 px-8 relative pb-20">
					
					<!-- Decoraciones de fondo (Sección Contacto) -->
					<div class="absolute right-12 top-20 w-32 h-32 opacity-80 pointer-events-none">
						<svg viewBox="0 0 150 150" fill="none" xmlns="http://www.w3.org/2000/svg" class="transform rotate-12">
							<pattern id="gridPattern2" width="15" height="15" patternUnits="userSpaceOnUse">
								<path d="M 15 0 L 0 0 0 15" fill="none" stroke="#94a3b8" stroke-width="1" />
							</pattern>
							<rect width="100" height="100" x="25" y="25" fill="url(#gridPattern2)" class="transform -rotate-12 origin-center" />
							<circle cx="50" cy="30" r="15" fill="#0ea5e9" />
						</svg>
					</div>
					<div class="absolute left-1/2 bottom-10 w-24 h-24 opacity-80 pointer-events-none -translate-x-12">
						<svg viewBox="0 0 100 100" fill="none" stroke="#0ea5e9" stroke-width="1.5" class="w-full h-full">
							<circle cx="50" cy="50" r="40" />
							<circle cx="50" cy="50" r="30" />
							<circle cx="50" cy="50" r="20" />
							<circle cx="50" cy="50" r="10" />
						</svg>
					</div>

					<!-- Columna Izquierda: Formulario -->
					<div class="flex flex-col z-10">
						<h2 class="text-[#007bff] text-4xl font-bold tracking-wide mb-12">Contáctanos!</h2>
						<form class="flex flex-col gap-8 w-full max-w-sm">
							<input type="text" placeholder="Nombre" class="w-full bg-transparent border-b border-slate-300 pb-2 focus:outline-none focus:border-[#007bff] text-slate-700 placeholder-slate-400 text-sm" />
							<input type="email" placeholder="Email" class="w-full bg-transparent border-b border-slate-300 pb-2 focus:outline-none focus:border-[#007bff] text-slate-700 placeholder-slate-400 text-sm" />
							<input type="text" placeholder="Detalles" class="w-full bg-transparent border-b border-slate-300 pb-2 focus:outline-none focus:border-[#007bff] text-slate-700 placeholder-slate-400 text-sm field-sizing-fixed"  />
							
							<button type="submit" class="w-20 h-10 mt-2 bg-indigo-500 rounded-full flex items-center justify-center text-white hover:bg-indigo-600 transition-colors">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</button>
						</form>
					</div>

					<!-- Columna Derecha: Info de Contacto -->
					<div class="flex flex-col z-10 mt-8 md:mt-0">
						<h2 class="text-indigo-200 text-4xl font-bold leading-tight mb-1">¿Tienes un proyecto<br/>en mente?</h2>
						
						<div class="flex flex-col gap-6 mt-8 md:mt-0">
							<div>
								<p class="text-slate-400 text-sm mb-1">Teléfono</p>
								<p class="text-slate-700 font-medium tracking-wide">+56 9 7245 7565</p>
								<p class="text-slate-700 font-medium tracking-wide">+56 9 4528 1079</p>
							</div>
							<div>
								<p class="text-slate-400 text-sm mb-1">Email</p>
								<p class="text-slate-700 font-medium tracking-wide">contacto@ddsol.cl</p>
							</div>
						</div>
					</div>
				</div>

			</div>
		</main>

		<!-- ==================== FOOTER ==================== -->
		<footer class="w-full bg-[#00c8f8] relative overflow-hidden text-white py-16 px-10">
			<!-- Opcional: Reemplazar el url() con el vector de puntos morados si lo tienes exportado -->
			<div class="absolute inset-0 opacity-30 pointer-events-none bg-[url('/ruta-al-patron-nodos.svg')] bg-cover bg-center"></div>
			
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 relative z-10">
				
				<!-- Izquierda: Logo y Descripción -->
				<div class="max-w-sm">
					<div class="flex items-center gap-3 mb-6">
						<!-- Icono Concept Softworks -->
						<svg viewBox="0 0 40 40" class="w-10 h-10 fill-white">
							<path d="M0 0h40v40H0z" fill-opacity="0"/>
							<path d="M10 10h20v20H10z" fill="currentColor"/>
							<path d="M30 10v20c0-11.046-8.954-20-20-20h20z" fill="#00c8f8"/>
						</svg>
						<div class="flex flex-col leading-none">
							<span class="text-2xl font-bold tracking-widest">CONCEPT</span>
							<span class="text-sm font-normal tracking-[0.2em] mt-1">SOFTWORKS</span>
						</div>
					</div>
					<p class="text-sm font-medium leading-relaxed opacity-90">
						DDSol es una compañía de software, desarrollamos soluciones personalizadas para tus necesidades.
					</p>
				</div>

				<!-- Derecha: Enlaces y Redes Sociales -->
				<div class="flex flex-col items-start md:items-end gap-10 mt-4 md:mt-0">
					<ul class="flex flex-wrap gap-6 text-[0.85rem] font-bold tracking-wide">
						<li><a href="#about" class="hover:text-indigo-900 transition-colors">About</a></li>
						<li><a href="#project" class="hover:text-indigo-900 transition-colors">Project</a></li>
						<li><a href="#service" class="hover:text-indigo-900 transition-colors">Service</a></li>
						<li><a href="#client" class="hover:text-indigo-900 transition-colors">Client</a></li>
						<li><a href="#team" class="hover:text-indigo-900 transition-colors">Team</a></li>
						<li><a href="#blog" class="hover:text-indigo-900 transition-colors">Blog</a></li>
						<li><a href="#contact" class="hover:text-indigo-900 transition-colors">Contact</a></li>
					</ul>
					
					<div class="flex items-center gap-6">
						<span class="text-sm font-bold tracking-widest flex flex-col leading-tight">
							<span>Fol</span>
							<span>low</span>
						</span>
						<!-- Íconos de Redes -->
						<div class="flex gap-3">
							<!-- Facebook -->
							<a href="#" class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-[#00c8f8] hover:bg-slate-100 transition-colors">
								<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
							</a>
							<!-- Instagram -->
							<a href="#" class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-[#00c8f8] hover:bg-slate-100 transition-colors">
								<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
							</a>
							<!-- Twitter -->
							<a href="#" class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-[#00c8f8] hover:bg-slate-100 transition-colors">
								<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
							</a>
						</div>
					</div>
				</div>
				
			</div>
		</footer>

	</body>
</html>